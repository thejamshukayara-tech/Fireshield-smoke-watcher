const path = require('path');
const http = require('http');
const express = require('express');
const cors = require('cors');
const { Server } = require('socket.io');
const { SerialPort } = require('serialport');
const { ReadlineParser } = require('@serialport/parser-readline');

// ─────────────────────────────────────────────
// CONFIGURATION — change these to match your PC
// ─────────────────────────────────────────────
const PORT        = 3000;          // dashboard port
const SERIAL_PORT = 'COM3';        // Arduino port (COM3, COM4, etc.)
const BAUD_RATE   = 9600;
const ALERT_THRESHOLD = 500;
// ─────────────────────────────────────────────

const app    = express();
const server = http.createServer(app);
const io     = new Server(server, {
  cors: { origin: '*', methods: ['GET', 'POST'] }
});

app.use(cors());
app.use(express.json());
app.use(express.static(path.join(__dirname, 'public')));

let latest = { smoke: 0, timestamp: Date.now(), alert: false };
const history = [];
const MAX_HISTORY = 50;

// ── REST endpoints ──────────────────────────
app.get('/health', (_req, res) => res.json({ ok: true, latest }));
app.get('/latest', (_req, res) => res.json({ latest, history }));

// Also accept manual POST (for testing with curl or Postman)
app.post('/smoke', (req, res) => {
  const value = Number(req.body && req.body.smoke);
  if (!Number.isFinite(value)) {
    return res.status(400).json({ error: 'Expected { "smoke": <number> }' });
  }
  processReading(value);
  res.json({ ok: true, latest });
});

// ── Socket.io ───────────────────────────────
io.on('connection', (socket) => {
  console.log('Browser connected:', socket.id);
  socket.emit('init', { latest, history });
  socket.on('disconnect', () => console.log('Browser disconnected:', socket.id));
});

// ── Serial port (Arduino via USB) ───────────
function startSerial() {
  const serial = new SerialPort({ path: SERIAL_PORT, baudRate: BAUD_RATE });
  const parser = serial.pipe(new ReadlineParser({ delimiter: '\n' }));

  serial.on('open', () => {
    console.log(⁠ Serial port ${SERIAL_PORT} open at ${BAUD_RATE} baud ⁠);
  });

  parser.on('data', (line) => {
    const value = parseInt(line.trim(), 10);
    if (!isNaN(value)) {
      console.log(⁠ Arduino → smoke: ${value} ⁠);
      processReading(value);
    }
  });

  serial.on('error', (err) => {
    console.error('Serial error:', err.message);
    console.log('Retrying in 5 seconds...');
    setTimeout(startSerial, 5000);
  });
}

// ── Shared reading handler ───────────────────
function processReading(value) {
  const reading = {
    smoke:     value,
    timestamp: Date.now(),
    alert:     value > ALERT_THRESHOLD
  };

  latest = reading;
  history.push(reading);
  if (history.length > MAX_HISTORY) history.shift();

  io.emit('smoke', reading);

  if (reading.alert) {
    console.warn(⁠ [ALERT] Smoke level ${value} exceeded ${ALERT_THRESHOLD}! ⁠);
    io.emit('alert', reading);
  }
}

// ── Start ────────────────────────────────────
startSerial();

server.listen(PORT, () => {
  console.log(⁠ Fireshield dashboard running at http://localhost:${PORT} ⁠);
});
{
  "name": "fireshield-smoke-watcher",
  "version": "1.0.0",
  "description": "Fireshield Smart Smoke Detector Dashboard",
  "main": "server.js",
  "scripts": {
    "start": "node server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "serialport": "^12.0.0",
    "socket.io": "^4.7.2"
  }
}
